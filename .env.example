# ---- Database (Railway Postgres) ----
DATABASE_URL="postgresql://user:password@localhost:5432/tulip?schema=public"

# ---- API ----
API_PORT=4000
JWT_SECRET="change-me-to-a-long-random-string"

# ---- Plaid (account aggregation) ----
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"            # sandbox | production

# ---- Property data (ATTOM or Zillow) ----
ATTOM_API_KEY=""

# ---- Flint / Anthropic (AI advisor layer) ----
ANTHROPIC_API_KEY=""
FLINT_MODEL="claude-sonnet-4-6"

# ---- Web ----
NEXT_PUBLIC_API_URL="http://localhost:4000"
