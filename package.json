{
  "name": "tulip",
  "version": "0.1.0",
  "private": true,
  "description": "Tulip — a financial wealth management platform that prescribes your next dollar, not just reports your last one.",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20.0.0", "pnpm": ">=9.0.0" },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @tulip/db generate",
    "db:migrate": "pnpm --filter @tulip/db migrate",
    "db:studio": "pnpm --filter @tulip/db studio",
    "db:seed": "pnpm --filter @tulip/db seed"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "prettier": "^3.3.0"
  }
}
